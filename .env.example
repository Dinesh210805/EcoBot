# === LLM APIs ===
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXA_API_KEY=exa-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Classifier Mode ===
# "ollama" for local/Docker (fine-tuned model), "groq" for serverless/Vercel
CLASSIFIER_MODE=ollama

# === Ollama (local fine-tuned model) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=ecobot-classifier

# === Groq Model Names ===
GROQ_RESPONSE_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_CLASSIFIER_MODEL=llama-3.3-70b-versatile

# === Database Paths ===
SQLITE_DB_PATH=./data/ecobot.db
CHROMA_DB_PATH=./embeddings/chroma_db

# === ChromaDB Collections ===
CHROMA_DISPOSAL_COLLECTION=disposal_guides
CHROMA_FACTS_COLLECTION=env_facts
CHROMA_PRODUCTS_COLLECTION=product_kb

# === RAG ===
RAG_TOP_K=3
RAG_SIMILARITY_THRESHOLD=0.70
EXA_SEARCH_NUM_RESULTS=3

# === API Settings ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT=60/minute

# === App ===
APP_ENV=development
LOG_LEVEL=INFO
MAX_BATCH_SIZE=20
MAX_IMAGE_SIZE_MB=10
UPLOAD_DIR=./tmp/uploads
